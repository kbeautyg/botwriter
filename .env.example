# Telegram
BOT_TOKEN=replace_me_via_BotFather

# Whitelist (запятая-разделитель TG user_id). Получи свой id у @userinfobot.
ALLOWED_USER_IDS=123456789,987654321

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL — оставь пустым для прямого OpenAI.
# Для прокси (vsegpt/proxyapi/openrouter): укажи их base_url, напр.
# OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_BASE_URL=https://api.vsegpt.ru/v1
# Тогда модели и формат запросов должны быть совместимы с OpenAI API (chat/completions + Whisper).
OPENAI_BASE_URL=
MODEL_WRITER=gpt-4o
MODEL_CRITIC=gpt-4o-mini
MODEL_STYLIST=gpt-4o-mini
MODEL_STT=whisper-1

# DB
# Локально: ./data/post_bot.sqlite
# Railway: смонтировать Volume на /data → DB_PATH=/data/post_bot.sqlite
DB_PATH=./data/post_bot.sqlite

# Pipeline
MAX_REWRITE_ITERATIONS=2
MIN_ACCEPTABLE_SCORE=5
AUTO_SAVE_AS_EXAMPLE_THRESHOLD=7

# Logging
LOG_LEVEL=INFO
